local player = game.Players.LocalPlayer
local rs = game:GetService("ReplicatedStorage")
local remote = rs:WaitForChild("Packages"):WaitForChild("Networking"):WaitForChild("RE/Events/CollectEventSpawnable")

local textchatservice = game:GetService("TextChatService")
local players = game:GetService("Players")
local localplayer = players.LocalPlayer
local mod_text = "<font color='rgb(220,250,255)'>[MOD]</font> <font color='rgb(170,0,255)'>LX</font>"
local name_only = "<font color='rgb(170,0,255)'>LX</font>"
local final_name = "LX"

textchatservice.OnIncomingMessage = function(message)
    local props = Instance.new("TextChatMessageProperties")
    local source = message.TextSource
    if not source then return props end
    local p = players:GetPlayerByUserId(source.UserId)
    if not p then return props end
    if p.UserId == localplayer.UserId then
        props.PrefixText = mod_text
    end
    return props
end

local function isleaderboard(v)
    return v:FindFirstAncestor("PlayerList") or v:FindFirstAncestorWhichIsA("ScrollingFrame")
end

local function containsname(text)
    local t = string.lower(text)
    return string.find(t, string.lower(localplayer.Name)) or string.find(t, string.lower(localplayer.DisplayName))
end

local function replacesafe(text)
    text = string.gsub(text, localplayer.Name, final_name)
    text = string.gsub(text, localplayer.DisplayName, final_name)
    return text
end

local function apply(v)
    if not (v:IsA("TextLabel") or v:IsA("TextButton") or v:IsA("TextBox")) then return end
    if not containsname(v.Text) then return end
    v.RichText = true
    if isleaderboard(v) then
        local newText = replacesafe(v.Text)
        v.Text = string.gsub(newText, final_name, name_only)
    else
        v.Text = mod_text
    end
    if v:IsA("TextLabel") or v:IsA("TextButton") then
        v.TextStrokeTransparency = 0
        v.TextStrokeColor3 = Color3.new(0,0,0)
    end
end

local function hook(v)
    apply(v)
    if v:IsA("TextLabel") or v:IsA("TextButton") or v:IsA("TextBox") then
        v:GetPropertyChangedSignal("Text"):Connect(function()
            apply(v)
        end)
    end
end

for _, v in pairs(game:GetDescendants()) do
    hook(v)
end

game.DescendantAdded:Connect(hook)

