local function farmear()
    while activo do
        for i = 1, 500 do
            if not activo then break end
            pcall(function()
                remote:FireServer()
            end)
        end
        task.wait()
    end
end

btn.MouseButton1Click:Connect(function()
    activo = not activo
    if activo then
        btn.BackgroundColor3 = Color3.fromRGB(60, 130, 200)
        btn.Text = "EVENT VERANO"
        coroutine.wrap(farmear)()
    else
        btn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
        btn.Text = "EVENT VERANO"
    end
end)
